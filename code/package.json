{
  "name": "@solanabr/anchor-agent-toolkit",
  "version": "0.1.0",
  "description": "Turn any Anchor IDL into agent-callable tools — ingestion, resolution, simulation, safety rails.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./adapters/jupiter": "./dist/adapters/jupiter.js",
    "./adapters/drift": "./dist/adapters/drift.js",
    "./adapters/kamino": "./dist/adapters/kamino.js",
    "./adapters/marginfi": "./dist/adapters/marginfi.js",
    "./adapters/squads": "./dist/adapters/squads.js"
  },
  "scripts": {
    "build": "tsc -p .",
    "test": "vitest run",
    "test:mainnet": "vitest run --config vitest.mainnet.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.30.1",
    "@solana/web3.js": "^1.95.0",
    "@solana/spl-token": "^0.4.8"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "@types/node": "^20.14.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}
